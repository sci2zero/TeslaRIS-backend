    ASSISTANT_WITH_MASTER
    ASSISTANT_WITH_MAGISTRATE
    ASSISTANT_WITH_DOCTORATE
    LECTURER
    SENIOR_LECTURER
    PROFESSOR_OF_VOCATIONAL_STUDIES
    ASSISTANT_PROFESSOR
    ASSOCIATE_PROFESSOR
    TEACHING_ASSISTANT
    FULL_PROFESSOR
    PROFESSOR_EMERITUS
    RETIRED_PROFESSOR
    RESEARCH_TRAINEE
    RESEARCH_ASSOCIATE
    SCIENTIFIC_COLLABORATOR
    SENIOR_SCIENTIFIC_COLLABORATOR
