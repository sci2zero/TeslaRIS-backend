    LocalDate dateAwarded
    LocalDate dateFrom
    LocalDate dateTo
    Boolean OAMandated
    String OAMandateUrl
    Boolean internalInvestment
  }
  
  class FundingPart{
    Funding funding
    Set<MultiLingualContent> description
