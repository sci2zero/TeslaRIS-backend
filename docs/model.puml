    Boolean competitive 
    Boolean renewable 
    LocalDate dateSubmitted
    LocalDate dateAwarded
    LocalDate dateFrom
    LocalDate dateTo
    Boolean OAMandated
    String OAMandateUrl
    Boolean internalInvestment
  }
  
