    USED_BY
    CITED_BY
    REPLACED_BY
    RESULT_OF ' also can link PREPRINT
    TOPIC_OF ' if a document is BOOK_REVIEW, SCIENTIFIC_CRITIC, TRANSLATION, then we can point to original document
    ' Moreover, it might be that a *Product (software, dataset, online resource) is the main topic of some journal article, etc. 
  }

}

package activity {
    
    class PersonActivity {
        Set<MultilingualContent> name
        Set<MultiLingualContent> description
        Set<MultiLingualContent> nameAbbreviation
        Set<MultiLingualContent> keywords
        Set<ResearchArea> researchAreas
        String adminNote
        Set<String> uris
        Set<OrganisationUnit> targetInstitutions
        LocalDate startDate
        LocalDate endDate         
    }
    
    class PersonTeachingActivity extends PersonActivity {
        PersonTeachingActivityCategory category
        
        PersonContribution contribution 
        ' for GRADUATE_EXAMINATION it should be PersonDocumentContribution, in the case it is linked with thesis, 
        ' otherwise it will be PersonEventContribution
        ' for COURSE_TAUGHT it should be PersonEventContribution 
        Involvement involvement 
        ' for INVITED_TEACHING it might be Employment
        
        String lectureHoursPerWeek
        String tutorialHoursPerWeek
        String labHoursPerWeek
        String otherContactHoursPerWeek
    }
    
    enum PersonTechingActivityCategory {
        GRADUATE_EXAMINATION
        COURSE_TAUGHT
        INVITED_TEACHING
    }
    
    
    class PersonSupervisingActivity extends PersonActivity {
        PersonSupervisingActivityCategory category
        
        Involvement involvement 
        ' for RESEARCH_BASED_DEGREE_SUPERVISION it might be Education, the certain person (activity owner) should be in 
        ' the list of supervisors (field in the Education)
        ' for MENTORING it might be Education with DegreeType INFORMAL_EDUCATION, the certain person (activity owner) should be in 
        ' the list of supervisors (field in the Education), topic of mentorship can be preserved in the field description (the Education entity)
    }
    
    enum PersonSupervisingActivityCategory {
        MENTORING 
        RESEARCH_BASED_DEGREE_SUPERVISION
    }
    
    class PersonAssessmentActivity extends PersonActivity {
        PersonAssessmentActivityCategory category
        
        PersonContribution contribution 
        ' for CONFERENCE_REVIEWING_REFEREEING it should be PersonEventContribution, 
        ' for JOURNAL_REVIEWING_REFEREEING, ADHOC_JOURNAL_ARTICLE_REVIEW it should be PersonPublicationSeriesContribution, 
        ' for GRANT_APPLICATION_ASSESSMENT it should be PersonFundingCallContribution
        Involvement involvement 
        ' for PROMOTION_TENURE_ASSESSMENT it might be Membership, probably the linked Membership is without OrgUnit, just affiliationStatement, because Committee is not a legal entity
        ' We have commission for assessment, which is an important entity for TeslaRIS internal process of assessment. However, it is not a public entity for person references, 
        ' therefore, suggestion is to use Membership for this purpose   
        Integer numberOfReviewsOrAssessment                            
    }
        
    enum PersonAssessmentActivityCategory {
        JOURNAL_REVIEWING_REFEREEING
        CONFERENCE_REVIEWING_REFEREEING
        GRANT_APPLICATION_ASSESSMENT
        ADHOC_JOURNAL_ARTICLE_REVIEW
        PROMOTION_TENURE_ASSESSMENT         
    }
    
    class PersonMembershipActivity extends PersonActivity {
        PersonMembershipActivityCategory category
        
        Involvement involvement 
        ' for CONSULTING_ADVISORY it might be Employment,  
        ' for MEMBERSHIP it might be Membership 
        ' for COMMITTEE_MEMBERSHIP it might be Membership, probably the linked Membership is without OrgUnit, just affiliationStatement, because Committee is not a legal entity
        ' We have commission for assessment, which is an important entity for TeslaRIS internal process of assessment. However, it is not a public entity for person references, 
        ' therefore, suggestion is to use Membership for this purpose                      
    }
        
    enum PersonMembershipActivityCategory {
        MEMBERSHIP 
        COMMITTEE_MEMBERSHIP
        CONSULTING_ADVISORY        
    }
    
    class PersonEventActivity extends PersonActivity {
        PersonEventActivityCategory category
        
        PersonEventContribution contribution  
        
        Set<MultilingualContent> case ' only for EXPERT_WITNESS
        Set<MultilingualContent> location-jurisdiction  ' only for EXPERT_WITNESS                           
    }
        
    enum PersonEventActivityCategory {
        EVENT_ADMINISTRATION
        EVENT_PARTICIPATION
        EXPERT_WITNESS        
    }
    
    class PersonProjectActivity extends PersonActivity {
        PersonProjectActivityCategory category
        PersonProjectContribution contribution                              
    }
        
    enum PersonProjectActivityCategory {
        PROJECT_PARTICIPATION       
    }
}

package project {

  class Project {
